{
  "name": "@norialabs/comm",
  "version": "0.1.0",
  "description": "Reusable TypeScript/JavaScript SDK for Onfon SMS and Meta WhatsApp messaging.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sms": {
      "types": "./dist/sms.d.ts",
      "import": "./dist/sms.js"
    },
    "./whatsapp": {
      "types": "./dist/whatsapp.d.ts",
      "import": "./dist/whatsapp.js"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thekiharani/ts-packages.git",
    "directory": "comm"
  },
  "homepage": "https://github.com/thekiharani/ts-packages/tree/main/comm#readme",
  "bugs": {
    "url": "https://github.com/thekiharani/ts-packages/issues"
  },
  "scripts": {
    "build": "tsup src/index.ts src/sms.ts src/whatsapp.ts src/webhooks.ts --format esm --dts --sourcemap --clean --target es2022 --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/test.mjs",
    "test:run": "npm run build && node scripts/run-node-tests.mjs",
    "test:coverage": "npm run build && c8 --reporter=text node scripts/run-node-tests.mjs",
    "prepublishOnly": "npm run typecheck && npm run test:run"
  },
  "keywords": [
    "sms",
    "whatsapp",
    "onfon",
    "meta",
    "messaging",
    "sdk",
    "noria"
  ],
  "author": "Noria Labs",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "c8": "^10.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2"
  }
}
