{
  "name": "@noria/payments",
  "version": "0.1.0",
  "description": "Reusable TypeScript/JavaScript SDK for M-PESA Daraja and SasaPay payments.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mpesa": {
      "types": "./dist/mpesa.d.ts",
      "import": "./dist/mpesa.js"
    },
    "./sasapay": {
      "types": "./dist/sasapay.d.ts",
      "import": "./dist/sasapay.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts src/mpesa.ts src/sasapay.ts --format esm --dts --sourcemap --clean --target es2022 --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/test.mjs",
    "test:run": "npm run build && node --test tests/**/*.test.mjs",
    "test:coverage": "npm run build && c8 --reporter=text node --test tests/**/*.test.mjs",
    "prepublishOnly": "npm run typecheck && npm run test:run"
  },
  "keywords": [
    "payments",
    "mpesa",
    "daraja",
    "sasapay",
    "sdk",
    "kenya",
    "noria"
  ],
  "author": "Noria Labs",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.5.2",
    "c8": "^10.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2"
  }
}
