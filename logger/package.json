{
  "name": "@norialabs/logger",
  "version": "0.1.0",
  "description": "Flexible structured JSON logger for Node.js services.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean --target node20 --out-dir dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/test.mjs",
    "test:run": "npm run build && node scripts/run-node-tests.mjs",
    "test:coverage": "npm run build && c8 --all --src dist --reporter=text --check-coverage --lines 100 --functions 100 --branches 100 node scripts/run-node-tests.mjs",
    "prepublishOnly": "npm run typecheck && npm run test:coverage"
  },
  "keywords": [
    "logger",
    "logging",
    "pino",
    "cloudwatch",
    "noria"
  ],
  "author": "Noria Labs",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.950.0",
    "pino": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "c8": "^10.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2"
  }
}
